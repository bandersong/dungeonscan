<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>en</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>DungeonScan</string>
    <key>CFBundleDisplayName</key>
    <string>DungeonScan</string>
    <key>CFBundleIconFile</key>
    <string>AppIcon</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>$(MARKETING_VERSION)</string>
    <key>CFBundleVersion</key>
    <string>$(CURRENT_PROJECT_VERSION)</string>
    <key>LSMinimumSystemVersion</key>
    <string>$(MACOSX_DEPLOYMENT_TARGET)</string>
    <key>NSHighResolutionCapable</key>
    <true/>
    <key>NSHumanReadableCopyright</key>
    <string>DungeonScan — local map/VTT perception. Images processed on-device.</string>
    <key>NSPrincipalClass</key>
    <string>NSApplication</string>
    <!-- Export compliance: no non-exempt encryption (standard system crypto
         only). Declares the exempt path so App Store Connect stops re-asking. -->
    <key>ITSAppUsesNonExemptEncryption</key>
    <false/>
    <!-- Sparkle auto-update (Developer ID build). SUPublicEDKey is the EdDSA
         public key; SUFeedURL is the appcast on GitHub. Updates are checked
         automatically (daily) and via the Check for Updates… menu item. -->
    <key>SUFeedURL</key>
    <string>https://raw.githubusercontent.com/bandersong/dungeonscan/master/appcast.xml</string>
    <key>SUPublicEDKey</key>
    <string>PLACEHOLDER_ED_PUBLIC_KEY</string>
    <key>SUEnableAutomaticChecks</key>
    <true/>
    <key>SUScheduledCheckInterval</key>
    <integer>86400</integer>
</dict>
</plist>
