<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>en</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>DungeonScan</string>
    <key>CFBundleDisplayName</key>
    <string>DungeonScan</string>
    <!-- App icon (ok if the AppIcon asset isn't present yet — Xcode warns, not errors). -->
    <key>CFBundleIconName</key>
    <string>AppIcon</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>$(MARKETING_VERSION)</string>
    <key>CFBundleVersion</key>
    <string>$(CURRENT_PROJECT_VERSION)</string>
    <key>LSRequiresIPhoneOS</key>
    <true/>
    <!-- Export compliance: no non-exempt encryption (standard system crypto
         only). Declares the exempt path so App Store Connect stops re-asking. -->
    <key>ITSAppUsesNonExemptEncryption</key>
    <false/>
    <key>NSHumanReadableCopyright</key>
    <string>DungeonScan — local map/VTT perception. Images processed on-device.</string>

    <!-- Status bar: default style, shown. The webview is full-screen and lays
         out under the status bar (safe-area insets are respected by the VC). -->
    <key>UIStatusBarStyle</key>
    <string>UIStatusBarStyleDefault</string>
    <key>UIViewControllerBasedStatusBarAppearance</key>
    <true/>

    <!-- Full screen (no external display / split priority games); the digitizer
         UI is the whole app. -->
    <key>UIRequiresFullScreen</key>
    <true/>

    <!-- Blank launch screen (system fills the screen with the background color
         while the WKWebView loads); an empty dict yields the default screen. -->
    <key>UILaunchScreen</key>
    <dict/>

    <!-- iPad: all four orientations; iPhone: portrait + landscape. -->
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>
    <key>UISupportedInterfaceOrientations~ipad</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>

    <!-- Privacy usage strings. Camera/Photos back the openImage action sheet
         (Take Photo / Choose Photo). CoreML + Vision need no usage string. -->
    <key>NSCameraUsageDescription</key>
    <string>Take a photo of your dungeon map to digitize it.</string>
    <key>NSPhotoLibraryUsageDescription</key>
    <string>Import a dungeon drawing to digitize it.</string>

    <!-- Scene-based lifecycle. The "Default" configuration names the
         SceneDelegate class (resolved via $(PRODUCT_MODULE_NAME)); AppDelegate's
         configurationForConnecting returns a matching UISceneConfiguration. -->
    <key>UIApplicationSceneManifest</key>
    <dict>
        <key>UIApplicationSupportsMultipleScenes</key>
        <false/>
        <key>UISceneConfigurations</key>
        <dict>
            <key>UIWindowSceneSessionRoleApplication</key>
            <array>
                <dict>
                    <key>UISceneConfigurationName</key>
                    <string>Default</string>
                    <key>UISceneDelegateClassName</key>
                    <string>$(PRODUCT_MODULE_NAME).SceneDelegate</string>
                </dict>
            </array>
        </dict>
    </dict>
</dict>
</plist>
